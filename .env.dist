# Окружение приложения: "dev" включает DEBUG, любое другое значение — прод-режим
APP_ENV=dev

# Секретный ключ Django (сгенерируйте уникальный для каждого окружения)
SECRET_KEY=

# DSN подключения к PostgreSQL: postgresql://<user>:<password>@<host>:<port>/<db>
POSTGRES_DSN=postgresql://verseyard:verseyard@db:5432/verseyard

# DSN подключения к Redis (используется как кэш и брокер Celery)
REDIS_DSN=redis://redis:6379/0

# Ключи для подписи JWT (RS256): PEM-содержимое приватного и публичного ключей
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Парольная фраза приватного ключа JWT (оставьте пустым, если ключ без пароля)
JWT_PASSPHRASE=

# Время жизни access-токена в секундах
JWT_TOKEN_TTL=3600

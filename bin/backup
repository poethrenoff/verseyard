#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 1 ]; then
  echo "Использование: $0 <каталог_для_бэкапов>"
  exit 1
fi

BACKUP_DIR="$1"
mkdir -p "$BACKUP_DIR"

TIMESTAMP="$(date +%Y%m%d_%H%M%S)"
BACKUP_FILE="$BACKUP_DIR/verseyard_${TIMESTAMP}.sql.gz"

echo "Создание бэкапа БД в $BACKUP_FILE ..."
docker compose exec -T db \
  pg_dump --clean --if-exists --no-owner --username=verseyard --dbname=verseyard \
  | gzip > "$BACKUP_FILE"

echo "Готово: $BACKUP_FILE"

#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 1 ]; then
  echo "Использование: $0 <каталог_бэкапов>"
  exit 1
fi

BACKUP_DIR="$1"

BACKUP_FILE="$(ls -1t "$BACKUP_DIR"/*.sql 2>/dev/null | head -n1 || true)"
if [ -z "$BACKUP_FILE" ]; then
  echo "В каталоге '$BACKUP_DIR' бэкапы не найдены."
  exit 1
fi

echo "Восстановление БД из $BACKUP_FILE ..."
docker compose exec -T db \
  psql --username=verseyard --dbname=verseyard \
  < "$BACKUP_FILE"

echo "Готово."
